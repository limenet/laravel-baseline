{
    "git": {
        "requireBranch": "main",
        "commitMessage": "chore: release v${version}",
        "tagName": "v${version}",
        "tagAnnotation": "Release v${version}"
    },
    "npm": false,
    "github": {
        "release": true,
        "releaseName": "v${version}"
    },
    "plugins": {
        "@release-it/bumper": {
            "in": {
                "file": "composer.json",
                "path": "version"
            },
            "out": {
                "file": "composer.json",
                "path": "version"
            }
        },
        "@release-it/conventional-changelog": {
            "infile": "CHANGELOG.md",
            "header": "# Changelog\n\nAll notable changes to `laravel-baseline` will be documented in this file.\n",
            "preset": {
                "name": "conventionalcommits"
            }
        }
    }
}
